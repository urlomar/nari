# Copy to .env.local and fill in real values. DO NOT COMMIT the real file.

# Google service account used to write to the waitlist Sheet.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Private key from the service account JSON key file.
# Keep real newlines escaped as \n (the API code converts \\n -> \n at runtime).
# Example: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=
# The Google Sheet ID (the long ID in the sheet URL).
GOOGLE_SHEET_ID=
# Optional: override the range used when appending rows. Defaults to Sheet1!A:E.
GOOGLE_SHEET_RANGE=

# Resend API key used to send confirmation emails.
RESEND_API_KEY=
# From-address used for outgoing email, e.g. "Nari <onboarding@resend.dev>".
NARI_FROM_EMAIL=
